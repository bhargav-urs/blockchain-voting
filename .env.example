# Copy this file to .env.local and fill in values after deployment.
# The deploy scripts automatically write .env.local for you.

# ── Blockchain ──────────────────────────────────────────────────────────────
# Polygon Amoy (testnet)
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology/
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_CHAIN_HEX=0x13882
NEXT_PUBLIC_CHAIN_NAME=Polygon Amoy
NEXT_PUBLIC_EXPLORER_BASE_URL=https://amoy.polygonscan.com

# ── Contract ─────────────────────────────────────────────────────────────────
# Set by deploy script automatically:
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_ADMIN_ADDRESS=

# ── Hardhat ──────────────────────────────────────────────────────────────────
# Deployer private key (keep secret, never commit)
PRIVATE_KEY=

# Optional: PolygonScan API key for contract verification
POLYGONSCAN_API_KEY=
